{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for Decentralized Todo App with MongoDB caching and blockchain sync",
  "main": "src/index.ts",
  "scripts": {
    "start": "node -r ts-node/register src/index.ts",
    "dev": "nodemon --exec 'node -r ts-node/register' src/index.ts",
    "build": "echo 'Backend is JavaScript + TypeScript (incremental migration) - no build step required'",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.{js,ts}"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "todo",
    "express",
    "mongodb"
  ],
  "author": "",
